FROM node:26-alpine@sha256:e71ac5e964b9201072425d59d2e876359efa25dc96bb1768cb73295728d6e4ea AS base
RUN npm install -g pnpm@10.33.4

FROM base AS deps
WORKDIR /app
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/
RUN pnpm install --frozen-lockfile

FROM base AS builder
WORKDIR /app
ENV NODE_OPTIONS=--max-old-space-size=6144
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=deps /app/packages/shared/node_modules ./packages/shared/node_modules
COPY . .
ARG PUBLIC_API_URL=""
ARG PUBLIC_APP_VERSION="0.1.0"
ARG PUBLIC_ENABLE_REGISTRATION="false"
ENV PUBLIC_API_URL=${PUBLIC_API_URL}
ENV PUBLIC_APP_VERSION=${PUBLIC_APP_VERSION}
ENV PUBLIC_ENABLE_REGISTRATION=${PUBLIC_ENABLE_REGISTRATION}
RUN pnpm --filter @breeze/web build
# Create a self-contained deployment (resolves pnpm symlinks).
# pnpm 10's deploy command requires workspace deps be declared injected.
# TODO: declare @breeze/shared (and other workspace deps) as injected in
# apps/web/package.json and drop --legacy. See pnpm v10 release notes.
RUN pnpm --filter @breeze/web deploy --legacy --prod /deployed

FROM base AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV HOST=0.0.0.0

RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 astro

# Copy the self-contained deployment (flat node_modules, no symlinks)
COPY --from=builder --chown=astro:nodejs /deployed/node_modules ./node_modules
COPY --from=builder --chown=astro:nodejs /deployed/dist ./dist
COPY --from=builder --chown=astro:nodejs /deployed/package.json ./

USER astro

EXPOSE 4321
CMD ["node", "./dist/server/entry.mjs"]
